# Frontend website domain, not the backend API domain.
FRONTEND_DOMAIN=your-frontend-domain.com

# Absolute path where the dist files will be published on the server.
DEPLOY_PATH=/var/www/volunteer-system-frontend

# Nginx config destination on the server.
NGINX_CONFIG_PATH=/etc/nginx/conf.d/volunteer-system-frontend.conf

# Temporary internal testing API base URL.
API_BASE_URL=http://eco.volunteer.com

# Switch to HTTPS after the backend TLS certificate is ready.
# API_BASE_URL=https://eco.volunteer.com
